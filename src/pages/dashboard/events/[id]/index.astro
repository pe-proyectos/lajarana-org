---
import Layout from '../../../../layouts/Layout.astro';
import EventWizard from '../../../../components/EventWizard.jsx';
import '../../../../styles/dashboard.css';
const { id } = Astro.params;
---
<Layout title="Editar Evento — LaJarana" description="Administra tu evento en LaJarana.">
  <div class="dash-layout">
    <header class="dash-header">
      <a href="/dashboard" class="logo"><img src="/logo.png" alt="LaJarana" style="height:48px;margin-right:8px;vertical-align:middle;" /> LaJarana</a>
    </header>
    <EventWizard eventId={id} client:load />
  </div>
</Layout>
