---
import Layout from '../layouts/Layout.astro';
import AnimatedCard from '../components/AnimatedCard.jsx';
---

<Layout title="LaJarana para Organizadores — Publica tu evento sin comisiones" description="Vende entradas para tus eventos sin comisiones. LaJarana, la plataforma de boletería digital para organizadores en Perú.">
  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="logo"><img src="/logo.png" alt="LaJarana" style="height:48px;margin-right:8px;vertical-align:middle;" /> LaJarana <span class="logo-tag">Organizadores</span></a>
      <div class="nav-links">
        <a href="#features">Características</a>
        <a href="#como-funciona">Cómo funciona</a>
        <a href="#planes">Planes</a>
        <a href="/login">Iniciar Sesión</a>
        <a href="/register" class="btn-primary" style="padding:10px 24px;font-size:0.9rem;">Empezar gratis</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero hero-bg">
    <div class="hero-blob hero-blob--1"></div>
    <div class="hero-blob hero-blob--2"></div>
    <div class="hero-blob hero-blob--3"></div>
    <div class="hero-content container" style="text-align:center;">
      <div class="hero-badge" data-aos="fade-up">🚀 Para organizadores de eventos</div>
      <h1 data-aos="fade-up" data-aos-delay="100">
        <span class="gradient-text">Publica tu evento</span><br/>sin comisiones.
      </h1>
      <p class="hero-sub" data-aos="fade-up" data-aos-delay="200">
        Vende entradas digitales con QR, gestiona asistentes y recibe tu dinero directamente. 0% comisión por ticket.
      </p>
      <div class="hero-actions" data-aos="fade-up" data-aos-delay="300">
        <a href="/register" class="btn-primary">Crear mi evento gratis →</a>
        <a href="https://dev-lajarana.luminari.agency" class="btn-secondary">Ver eventos publicados</a>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <span>★ 0% Comisión</span><span>★ QR Anti-fraude</span><span>★ Analytics</span>
      <span>★ Dashboard</span><span>★ Pagos directos</span><span>★ Control de acceso</span>
      <span>★ 0% Comisión</span><span>★ QR Anti-fraude</span><span>★ Analytics</span>
      <span>★ Dashboard</span><span>★ Pagos directos</span><span>★ Control de acceso</span>
    </div>
  </div>

  <!-- SOCIAL PROOF / STATS -->
  <section class="section--stats">
    <div class="container" style="text-align:center;">
      <div class="stats-counter-grid" data-aos="fade-up">
        <div class="stat-counter-item">
          <span class="stat-counter-value" data-count="0">0</span><span class="stat-counter-suffix">%</span>
          <span class="stat-counter-label">comisión</span>
        </div>
        <div class="stat-counter-divider">·</div>
        <div class="stat-counter-item">
          <span class="stat-counter-value" data-count="10">0</span>
          <span class="stat-counter-label">eventos gratis</span>
        </div>
        <div class="stat-counter-divider">·</div>
        <div class="stat-counter-item">
          <span class="stat-counter-label" style="font-size:1.1rem;color:var(--white-80);">La plataforma de boletería digital para organizadores en Perú</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="gradient-separator" />

  <!-- FEATURES -->
  <section id="features" class="section--features">
    <div class="container">
      <h2 class="section-title" data-aos="fade-up">Todo lo que necesitas para <span class="gradient-text">gestionar eventos</span></h2>
      <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100">Herramientas profesionales sin complicaciones.</p>
      <div class="features-grid">
        <AnimatedCard client:visible className="feature-card" delay={0} glowColor="var(--lime)">
          <div class="feature-icon">💰</div>
          <h3>0% Comisión</h3>
          <p>No cobramos comisión por ticket vendido. El dinero de tus ventas va 100% a tu cuenta.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="feature-card" delay={0.1} glowColor="var(--violet)">
          <div class="feature-icon">📊</div>
          <h3>Analytics en tiempo real</h3>
          <p>Ventas, ingresos, asistencia — todo en un dashboard que se actualiza al instante.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="feature-card" delay={0.2} glowColor="var(--coral)">
          <div class="feature-icon">📱</div>
          <h3>Control de acceso QR</h3>
          <p>Escanea QR en puerta, controla aforo en tiempo real. Rápido y seguro.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="feature-card" delay={0.3} glowColor="var(--violet)">
          <div class="feature-icon">🎨</div>
          <h3>Página del evento</h3>
          <p>Cada evento tiene su propia página pública con toda la info y venta de entradas integrada.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="feature-card" delay={0.4} glowColor="var(--lime)">
          <div class="feature-icon">🔒</div>
          <h3>QR Anti-fraude</h3>
          <p>Códigos QR únicos y encriptados. Imposible duplicar o falsificar entradas.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="feature-card" delay={0.5} glowColor="var(--coral)">
          <div class="feature-icon">⚡</div>
          <h3>Setup en minutos</h3>
          <p>Crea tu evento, configura entradas y empieza a vender en menos de 5 minutos.</p>
        </AnimatedCard>
      </div>
    </div>
  </section>

  <hr class="gradient-separator" />

  <!-- HOW IT WORKS -->
  <section id="como-funciona" class="section--steps">
    <div class="container">
      <h2 class="section-title" data-aos="fade-up">Cómo <span class="gradient-text">funciona</span></h2>
      <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100">Empieza a vender entradas en 3 simples pasos.</p>
      <div class="steps-grid">
        <AnimatedCard client:visible className="step-card" delay={0} glowColor="var(--violet)">
          <div class="step-number step-number--violet">1</div>
          <h3>Crea tu evento</h3>
          <p>Añade título, descripción, fecha, lugar y portada. Nuestro wizard te guía paso a paso.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="step-card" delay={0.1} glowColor="var(--lime)">
          <div class="step-number step-number--lime">2</div>
          <h3>Configura entradas</h3>
          <p>Define tipos de entrada, precios, cantidades y descripciones. Publica cuando estés listo.</p>
        </AnimatedCard>
        <AnimatedCard client:visible className="step-card" delay={0.2} glowColor="var(--coral)">
          <div class="step-number step-number--coral">3</div>
          <h3>Vende y gestiona</h3>
          <p>Comparte tu link, vende entradas y controla todo desde tu dashboard. Escanea QR en puerta.</p>
        </AnimatedCard>
      </div>
    </div>
  </section>

  <hr class="gradient-separator" />

  <!-- PRICING -->
  <section id="planes" class="section--pricing">
    <div class="container">
      <div class="pricing-hero-badge" data-aos="fade-up">0% COMISIÓN POR TICKET — SIEMPRE</div>
      <h2 class="section-title" data-aos="fade-up">Planes <span class="gradient-text">transparentes</span></h2>
      <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100">Sin comisiones ocultas. El dinero de tus ventas va 100% a tu cuenta.</p>
      <div class="pricing-grid pricing-grid--4col">
        <!-- GRATIS -->
        <div class="pricing-card pricing-card--hoverable island" data-aos="fade-up" data-aos-delay="0">
          <div class="pricing-badge">Gratis</div>
          <div class="pricing-price">
            <span class="pricing-amount">S/ 0</span>
          </div>
          <p class="pricing-tagline pricing-tagline--lime">Primeros 10 eventos</p>
          <p class="pricing-desc">Tus primeros 10 eventos son gratis. Sin costo, sin comisión, nada.</p>
          <div class="pricing-commission-badge"><span class="commission-zero">0%</span> comisión</div>
          <div class="pricing-divider"></div>
          <ul class="pricing-features">
            <li><span class="pricing-check">✓</span> 10 eventos sin costo</li>
            <li><span class="pricing-check">✓</span> 0% comisión por ticket</li>
            <li><span class="pricing-check">✓</span> QR anti-fraude</li>
            <li><span class="pricing-check">✓</span> Página pública del evento</li>
            <li><span class="pricing-check">✓</span> Dashboard completo</li>
            <li><span class="pricing-check">✓</span> Soporte por chat</li>
          </ul>
          <a href="/register" class="btn-secondary pricing-cta">Comenzar gratis</a>
        </div>
        <!-- POR EVENTO (Paquetes) -->
        <div class="pricing-card pricing-card--hoverable island" data-aos="fade-up" data-aos-delay="100">
          <div class="pricing-badge pricing-badge--coral">Paquetes</div>
          <div class="pricing-price">
            <span class="pricing-amount">Desde S/ 300</span>
          </div>
          <p class="pricing-tagline pricing-tagline--coral">Pago único por evento</p>
          <p class="pricing-desc">Tarifa fija según la capacidad de tickets. Sin sorpresas.</p>
          <div class="pricing-commission-badge"><span class="commission-zero">0%</span> comisión</div>
          <div class="pricing-divider"></div>
          <div class="pricing-tiers">
            <div class="pricing-tier-row"><span class="tier-label">0–100 tickets</span><span class="tier-value">S/ 300</span></div>
            <div class="pricing-tier-row"><span class="tier-label">101–1,000 tickets</span><span class="tier-value">S/ 500</span></div>
            <div class="pricing-tier-row"><span class="tier-label">1,001+ tickets</span><span class="tier-value">S/ 1,000</span></div>
          </div>
          <ul class="pricing-features">
            <li><span class="pricing-check pricing-check--coral">✓</span> 0% comisión por ticket</li>
            <li><span class="pricing-check pricing-check--coral">✓</span> Todas las features</li>
            <li><span class="pricing-check pricing-check--coral">✓</span> Analytics en tiempo real</li>
            <li><span class="pricing-check pricing-check--coral">✓</span> Control de acceso QR</li>
          </ul>
          <a href="/register" class="btn-secondary pricing-cta">Elegir paquete</a>
        </div>
        <!-- POR TICKET -->
        <div class="pricing-card pricing-card--hoverable pricing-card--popular island" data-aos="fade-up" data-aos-delay="200">
          <div class="pricing-popular pricing-popular--lime">🔥 Popular</div>
          <div class="pricing-badge pricing-badge--lime">Por Ticket</div>
          <div class="pricing-price">
            <span class="pricing-amount">S/ 3</span>
            <span class="pricing-period">/ticket</span>
          </div>
          <p class="pricing-tagline pricing-tagline--lime">Paga solo lo que vendes</p>
          <p class="pricing-desc">Sin pago adelantado. Se descuenta S/3 por cada ticket vendido. Ideal para empezar.</p>
          <div class="pricing-commission-badge"><span class="commission-zero">0%</span> comisión extra</div>
          <div class="pricing-divider"></div>
          <ul class="pricing-features">
            <li><span class="pricing-check">✓</span> Sin pago adelantado</li>
            <li><span class="pricing-check">✓</span> S/3 por ticket vendido</li>
            <li><span class="pricing-check">✓</span> Todas las features incluidas</li>
            <li><span class="pricing-check">✓</span> QR anti-fraude</li>
            <li><span class="pricing-check">✓</span> Analytics en tiempo real</li>
            <li><span class="pricing-check">✓</span> Eventos ilimitados</li>
          </ul>
          <a href="/register" class="btn-primary pricing-cta">Empezar con Por Ticket →</a>
        </div>
        <!-- ILIMITADO -->
        <div class="pricing-card pricing-card--hoverable pricing-card--featured island" data-aos="fade-up" data-aos-delay="300">
          <div class="pricing-popular">⭐ Recomendado</div>
          <div class="pricing-badge pricing-badge--pro">Ilimitado</div>
          <div class="pricing-price">
            <span class="pricing-amount">S/ 799</span>
            <span class="pricing-period">/mes</span>
          </div>
          <p class="pricing-tagline">Eventos ilimitados</p>
          <p class="pricing-desc">Sin pago por evento ni por ticket. Para organizadores que hacen múltiples eventos al mes.</p>
          <div class="pricing-commission-badge"><span class="commission-zero">0%</span> comisión</div>
          <div class="pricing-divider"></div>
          <ul class="pricing-features">
            <li><span class="pricing-check pricing-check--pro">✓</span> Eventos ilimitados</li>
            <li><span class="pricing-check pricing-check--pro">✓</span> 0% comisión por ticket</li>
            <li><span class="pricing-check pricing-check--pro">✓</span> Sin pago por evento</li>
            <li><span class="pricing-check pricing-check--pro">✓</span> Analytics avanzados</li>
            <li><span class="pricing-check pricing-check--pro">✓</span> Soporte prioritario</li>
            <li><span class="pricing-check pricing-check--pro">✓</span> API access</li>
            <li><span class="pricing-check pricing-check--pro">✓</span> Widget personalizable</li>
          </ul>
          <a href="/register" class="btn-primary pricing-cta">Comenzar con Ilimitado →</a>
        </div>
      </div>

      <div class="payment-methods" data-aos="fade-up" data-aos-delay="200">
        <p class="payment-methods__title">Métodos de pago aceptados</p>
        <div class="payment-methods__grid">
          <span class="payment-pill">Yape</span>
          <span class="payment-pill">Plin</span>
          <span class="payment-pill">MercadoPago</span>
          <span class="payment-pill">Visa / Mastercard</span>
        </div>
        <p class="payment-methods__note">Pagos seguros. El dinero va directo a la cuenta del organizador.</p>
      </div>
    </div>
  </section>

  <hr class="gradient-separator" />

  <!-- CTA -->
  <section style="padding:80px 0;text-align:center;">
    <div class="container">
      <h2 class="section-title" data-aos="fade-up">¿Listo para <span class="gradient-text">empezar</span>?</h2>
      <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100" style="margin:0 auto 32px;">Crea tu primer evento gratis en menos de 5 minutos.</p>
      <a href="/register" class="btn-primary" data-aos="fade-up" data-aos-delay="200">Crear mi evento gratis →</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <div class="logo"><img src="/logo.png" alt="LaJarana" style="height:48px;margin-right:8px;vertical-align:middle;" /> LaJarana</div>
        <p>Plataforma para organizadores de eventos en Perú.</p>
      </div>
      <div class="footer-links">
        <div>
          <h4>Plataforma</h4>
          <a href="#features">Características</a>
          <a href="#como-funciona">Cómo funciona</a>
          <a href="#planes">Planes</a>
        </div>
        <div>
          <h4>Cuenta</h4>
          <a href="/login">Iniciar sesión</a>
          <a href="/register">Registrarse</a>
          <a href="/dashboard">Dashboard</a>
        </div>
        <div>
          <h4>Eventos</h4>
          <a href="https://dev-lajarana.luminari.agency">Ver eventos publicados →</a>
        </div>
        <div>
          <h4>Legal</h4>
          <a href="/terminos">Términos y Condiciones</a>
          <a href="/privacidad">Política de Privacidad</a>
        </div>
      </div>
      <div class="footer-bottom">
        <hr class="gradient-separator" style="margin-bottom:24px;" />
        <p>© 2026 LaJarana. Hecho con 💜 por <a href="https://luminari.agency" class="luminari-link">Luminari Agency</a></p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px 0;
    background: rgba(10,10,10,0.8);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--white-06);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .logo-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--violet);
    padding: 3px 10px;
    border: 1px solid var(--violet-20);
    border-radius: 50px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav-links a {
    color: var(--white-60);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }

  /* HERO */
  .hero-bg {
    background: linear-gradient(135deg, #0A0A0A 0%, #1a0a2e 25%, #0a1a0a 50%, #0A0A0A 75%);
    background-size: 400% 400%;
    animation: gradientShift 15s ease infinite;
  }
  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .hero {
    padding: 160px 0 100px;
    position: relative;
    text-align: center;
    overflow: hidden;
  }
  .hero-content { position: relative; z-index: 1; }
  .hero-badge {
    display: inline-block;
    padding: 6px 18px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-60);
    border: 1px solid var(--white-10);
    border-radius: 50px;
    margin-bottom: 32px;
    background: rgba(255,255,255,0.03);
  }
  .hero h1 {
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: 1.2rem;
    color: var(--white-60);
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* FEATURES */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }
  :global(.feature-card) { padding: 36px 28px; }
  :global(.feature-icon) { font-size: 2.5rem; margin-bottom: 16px; }
  :global(.feature-card h3) { font-size: 1.2rem; margin-bottom: 10px; }
  :global(.feature-card p) { color: var(--white-60); font-size: 0.95rem; }

  /* STEPS */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  :global(.step-card) { padding: 40px 32px; text-align: center; }
  :global(.step-number) {
    width: 52px; height: 52px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1.2rem; margin-bottom: 20px; color: var(--white);
  }
  :global(.step-number--violet) { background: var(--violet); box-shadow: 0 0 20px var(--violet-20); }
  :global(.step-number--lime) { background: var(--lime); color: var(--bg); box-shadow: 0 0 20px var(--lime-20); }
  :global(.step-number--coral) { background: var(--coral); box-shadow: 0 0 20px var(--coral-20); }
  :global(.step-card h3) { font-size: 1.3rem; margin-bottom: 12px; }
  :global(.step-card p) { color: var(--white-60); font-size: 0.95rem; }

  /* PRICING */
  .pricing-hero-badge {
    display: inline-block;
    padding: 10px 28px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--white);
    background: linear-gradient(135deg, var(--violet), var(--coral));
    border-radius: 50px;
    margin-bottom: 24px;
  }
  .pricing-grid--4col {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }
  .pricing-grid--3col {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }
  .pricing-card {
    padding: 40px 32px;
    text-align: left;
    position: relative;
  }
  .pricing-card--featured {
    border: 1px solid rgba(139,92,246,0.3);
    background: rgba(139,92,246,0.06);
  }
  .pricing-card--featured::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--radius);
    padding: 1px;
    background: linear-gradient(135deg, var(--violet), var(--coral));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    animation: border-glow 4s ease-in-out infinite alternate;
  }
  @keyframes border-glow {
    0% { opacity: 0.3; }
    100% { opacity: 0.8; }
  }
  .pricing-popular {
    position: absolute;
    top: -12px;
    left: 32px;
    background: var(--violet);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .pricing-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white-60);
    margin-bottom: 12px;
  }
  .pricing-badge--pro { color: var(--violet); }
  .pricing-badge--coral { color: var(--coral); }
  .pricing-price { margin-bottom: 4px; }
  .pricing-amount { font-size: 2.5rem; font-weight: 700; color: var(--white); }
  .pricing-period { font-size: 0.9rem; color: var(--white-60); }
  .pricing-tagline { font-size: 0.85rem; color: var(--violet); font-weight: 600; margin-bottom: 12px; }
  .pricing-tagline--lime { color: var(--lime); }
  .pricing-tagline--coral { color: var(--coral); }
  .pricing-commission-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 6px 16px;
    background: rgba(163,230,53,0.1);
